# Git Ignore Rules for Rental Marketplace

# ==================== Node Dependencies ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ==================== Environment Variables ====================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example
# ==================== IDE & Editor ====================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.prettierignore

# ==================== Build Files ====================
build/
dist/
.next/
out/

# ==================== Temporary Files ====================
tmp/
temp/
*.log
*.tmp

# ==================== OS ====================
.DS_Store
Thumbs.db
Desktop.ini

# ==================== Testing ====================
coverage/
.nyc_output/

# ==================== Backend Specific ====================
backend/node_modules/
backend/.env
backend/test-users.json
backend/uploads/
backend/uploads/
backend/logs/

# ==================== Frontend Specific ====================
frontend/node_modules/
frontend/.env
frontend/build/
frontend/.eslintcache
