{
  "name": "rental-marketplace-backend",
  "version": "1.0.0",
  "description": "My Rental Marketplace Backend - MERN Stack",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "seed": "node seed.js --clear",
    "seed:append": "node seed.js --append",
    "seed:small": "node seed.js --clear --users=10 --listings=20 --bookings=10",
    "seed:large": "node seed.js --clear --users=100 --listings=200 --bookings=150",
    "seed:verify": "node verify-seed.js",
    "export:users": "node export-users.js"
  },
  "keywords": [
    "rental",
    "marketplace",
    "pakistan"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "dotenv": "^16.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.3.0",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0",
    "cloudinary": "^1.35.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "jest": "^29.5.0"
  }
}
